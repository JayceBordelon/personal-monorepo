# vibetradez.com/server — trading API server.
# Copy to .env and fill in. All required vars cause the service to log.Fatal on boot if missing.

# ---- Required ----

# Postgres connection for the vibetradez DB.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/vibetradez?sslmode=require

# Transactional email (morning picks, EOD summary, weekly report).
RESEND_API_KEY=re_...

# OpenAI API key powering the morning trade analyzer (GPT).
OPENAI_API_KEY=sk-...

# Centralized auth service (auth.jaycebordelon.com). Trading server is a
# registered OAuth consumer; these credentials MUST match an entry in the
# auth service's OAUTH_CLIENTS_JSON.
VT_AUTH_BASE_URL=https://auth.jaycebordelon.com
VT_AUTH_CLIENT_ID=vibetradez
VT_AUTH_CLIENT_SECRET=CHANGE_ME_MATCH_AUTH_SERVICE
VT_AUTH_REDIRECT_URI=https://vibetradez.com/auth/sso/callback

# ---- Optional ----

# Public URL of the auth service that the browser is redirected to during
# /auth/sso/start. Defaults to https://auth.jaycebordelon.com.
VT_AUTH_PUBLIC_URL=https://auth.jaycebordelon.com

# Session cookie the trading server sets on vibetradez.com after OAuth
# callback. Holds the opaque access token issued by auth service.
SESSION_COOKIE_NAME=vt_session
SESSION_TTL_DAYS=30

# Anthropic validator. Optional — if unset, Claude scoring is skipped and
# trades persist with claude_score=0.
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides. Defaults are set in internal/config/config.go and
# should be refreshed when the official Go SDKs ship new defaults.
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-opus-4-7

# Schwab Market Data OAuth. Optional — live quotes degrade gracefully
# when unset. Complete the OAuth dance by visiting /auth/schwab.
SCHWAB_APP_KEY=
SCHWAB_SECRET=
SCHWAB_CALLBACK_URL=https://vibetradez.com/auth/callback

# Email defaults.
EMAIL_FROM=Vibe Tradez <trades@vibetradez.com>
# Comma-separated list of seed subscribers inserted on first boot.
EMAIL_RECIPIENTS=

# Cron schedules (Eastern time). Leave as defaults for production.
CRON_SCHEDULE_OPEN=25 9 * * 1-5
CRON_SCHEDULE_CLOSE=5 16 * * 1-5
CRON_SCHEDULE_WEEKLY=30 16 * * 5

# HTTP port the server listens on inside its container. Traefik routes
# vibetradez.com /api/*, /auth/*, /health to this port.
SERVER_PORT=8080

# ---- Auto-execution (paper or live trading via Schwab Trader API) ----
#
# Master switch. When false (default), the entire auto-execution pipeline
# is dormant — no decisions are written, no emails are sent, no orders
# are placed. Flip to true ONLY after the rest of this section is set.
TRADING_ENABLED=false

# paper | live. Anything other than the literal string "live" resolves
# to paper — there is no fallback to live on misconfiguration. paper
# mode synthesizes fills from current Schwab option marks; live mode
# submits real orders to the Schwab Trader API.
#
# Going live ALSO requires: (1) "Accounts and Trading" product added to
# the app at developer.schwab.com, (2) re-running /auth/schwab to
# refresh the OAuth token with trading scope, (3) options approval
# Level 1+ on the Schwab brokerage account.
TRADING_MODE=paper

# 32+ byte secret used to HMAC-sign the email confirmation tokens.
# Generate with: openssl rand -hex 32
# Required when TRADING_ENABLED=true (server log.Fatal's at boot if missing).
# Different from SCHWAB_SECRET — do NOT reuse.
EXECUTION_HMAC_SECRET=

# Single recipient for execution emails (defense in depth vs the
# subscriber list). All confirmation, receipt, and alert emails go ONLY
# to this address.
EXECUTION_RECIPIENT=bordelonjayce@gmail.com

# Public URL the email links resolve to. The /execute confirmation page
# lives at <PUBLIC_BASE_URL>/execute?token=...&action=...
PUBLIC_BASE_URL=https://vibetradez.com
